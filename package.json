{
  "name": "anki-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "esbuild src/server/index.ts --bundle --platform=node --format=esm --packages=external --outfile=dist/server/index.js && node dist/server/index.js",
    "dev:client": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build && esbuild src/server/index.ts --bundle --platform=node --format=esm --packages=external --outfile=dist/server/index.js",
    "build:node": "bash scripts/build-node.sh",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "hash:password": "bun src/server/hash-password.ts",
    "smoke:local": "bun run build && bash scripts/smoke-local.sh",
    "smoke:coolify": "bash scripts/smoke-coolify.sh",
    "db:migrate": "esbuild src/server/db/migrate.ts --bundle --platform=node --format=esm --packages=external --outfile=dist/server/migrate.js && node dist/server/migrate.js"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@node-rs/argon2": "^2.0.2",
    "@vitejs/plugin-react": "^5.0.0",
    "better-sqlite3": "^12.2.0",
    "cheerio": "^1.1.2",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.44.0",
    "hono": "^4.10.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.554.0",
    "openai": "^6.8.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "ts-fsrs": "^5.0.0",
    "zod": "^4.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "typescript": "^5.9.0",
    "vite": "^7.2.0",
    "vitest": "^4.0.0"
  }
}
